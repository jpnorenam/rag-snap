*.snap
/bin
*__debug*
# Editor artifacts
*.swp
*.swo
*~
# Local-only docs (see CLAUDE.md's own conventions section)
/PLAN.md
# Test Files
*.json
dev.config 
/cli
snapctl-fake
rag
# Folders
.craft/
bin-fake/
parts/
prime/
samples/
stage/
.vscode/
test-rfp/
# Export artifacts
*-export/
*-export.tar.gz
batch-*.yaml
*.json
batch-*.json
ubuntu-pro-questions.yaml
./cli
test-kb/
test-questions/
test-rfp/

# UI project files: the broad *.json rule above would otherwise swallow the
# UI's package manifests. npm ci (used by `make ui` and the snapcraft build)
# requires a committed lockfile, so these must be tracked.
!ui/package.json
!ui/package-lock.json
!ui/tsconfig.json
# Build artifacts and deps are not tracked (the UI build regenerates them).
ui/node_modules/
ui/.next/
ui/out/
ui/next-env.d.ts
ui/tsconfig.tsbuildinfo

# UX planning docs are working notes, not shipped documentation — keep them
# local (mirrors the PLAN.md convention).
docs/ux/

# The embedded UI dist holds only a committed placeholder index.html; the real
# SPA is copied in by `make ui` / the snapcraft build and must not be committed.
# (A nested .gitignore can't work here: the root rule above ignores every file
# named .gitignore.)
internal/webui/dist/*
!internal/webui/dist/index.html
